  <DTS:Executables>
    <DTS:Executable
      DTS:refId="Package\Execute SQL Task Get MinMax Date"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{D9DE6246-291B-43CF-91BB-FD6B7C9EA803}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Execute SQL Task Get MinMax Date"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{9BC290F5-8784-487D-9B57-4BB76D6DD9AB}"
          SQLTask:SqlStatementSource="SELECT&#xA;    MIN(OrderDate) AS MinDate,&#xA;    MAX(OrderDate) AS MaxDate&#xA;FROM (&#xA;    SELECT DATEADD(YEAR, 2, OrderDate) AS OrderDate&#xA;    FROM Data_DS1.Sales.SalesOrderHeader&#xA;&#xA;    UNION ALL&#xA;&#xA;    SELECT ORDERDATE AS OrderDate&#xA;    FROM Data_DS2.dbo.ORDERS&#xA;) x;"
          SQLTask:ResultType="ResultSetType_SingleRow" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
          <SQLTask:ResultBinding
            SQLTask:ResultName="0"
            SQLTask:DtsVariableName="User::MinDate" />
          <SQLTask:ResultBinding
            SQLTask:ResultName="1"
            SQLTask:DtsVariableName="User::MaxDate" />
        </SQLTask:SqlTaskData>
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\For Loop Container Generate DimDate"
      DTS:AssignExpression="@[User::CurrentDate] = DATEADD(&quot;day&quot;, 1, @[User::CurrentDate])"
      DTS:CreationName="STOCK:FORLOOP"
      DTS:Description="For Loop Container"
      DTS:DTSID="{33822970-DFDA-4B5B-8CF9-68DC86DB23E3}"
      DTS:EvalExpression="@[User::CurrentDate] &lt;= @[User::MaxDate]"
      DTS:ExecutableType="STOCK:FORLOOP"
      DTS:InitExpression="@[User::CurrentDate] = @[User::MinDate]"
      DTS:LocaleID="-1"
      DTS:MaxConcurrent="1"
      DTS:ObjectName="For Loop Container Generate DimDate">
      <DTS:Variables />
      <DTS:Executables>
        <DTS:Executable
          DTS:refId="Package\For Loop Container Generate DimDate\Execute SQL Task Insert Current Date"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Execute SQL Task"
          DTS:DTSID="{1B78724A-C883-4217-BEE9-50F2E1A53FAB}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="Execute SQL Task Insert Current Date"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{9BC290F5-8784-487D-9B57-4BB76D6DD9AB}"
              SQLTask:SqlStatementSource="DECLARE @d DATE = ?;&#xA;&#xA;IF NOT EXISTS (&#xA;    SELECT 1&#xA;    FROM dbo.DimDate&#xA;    WHERE FullDate = @d&#xA;)&#xA;BEGIN&#xA;    INSERT INTO dbo.DimDate (&#xA;        DateKey,&#xA;        FullDate,&#xA;        Day,&#xA;        Month,&#xA;        MonthName,&#xA;        Quarter,&#xA;        Year,&#xA;        WeekOfYear,&#xA;        DayOfWeek&#xA;    )&#xA;    VALUES (&#xA;        CONVERT(INT, FORMAT(@d, 'yyyyMMdd')),&#xA;        @d,&#xA;        DAY(@d),&#xA;        MONTH(@d),&#xA;        DATENAME(MONTH, @d),&#xA;        DATEPART(QUARTER, @d),&#xA;        YEAR(@d),&#xA;        DATEPART(ISO_WEEK, @d),&#xA;        DATEPART(WEEKDAY, @d)&#xA;    );&#xA;END" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
              <SQLTask:ParameterBinding
                SQLTask:ParameterName="0"
                SQLTask:DtsVariableName="User::CurrentDate"
                SQLTask:ParameterDirection="Input"
                SQLTask:DataType="7"
                SQLTask:ParameterSize="-1" />
            </SQLTask:SqlTaskData>
          </DTS:ObjectData>
        </DTS:Executable>
      </DTS:Executables>
    </DTS:Executable>
  </DTS:Executables>
