      DTS:refId="Package\Execute SQL Task"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{257AC6AB-03C1-4E5E-BC84-12BC3B531208}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Execute SQL Task"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{8DC98B10-DBDA-468E-84A9-7A12E685EBFB}"
          SQLTask:SqlStatementSource="WITH XMLNAMESPACES (&#xA;    'http://schemas.microsoft.com/sqlserver/2004/07/adventure-works/IndividualSurvey' AS ns&#xA;)&#xA;UPDATE Staging_Individual&#xA;SET &#xA;    BirthDate     = x.c.value('(ns:BirthDate)[1]', 'DATE'),&#xA;    MaritalStatus = x.c.value('(ns:MaritalStatus)[1]', 'CHAR(1)'),&#xA;    YearlyIncome  = x.c.value('(ns:YearlyIncome)[1]', 'NVARCHAR(50)'),&#xA;    Gender        = x.c.value('(ns:Gender)[1]', 'CHAR(1)'),&#xA;    TotalChildren = x.c.value('(ns:TotalChildren)[1]', 'TINYINT')&#xA;FROM Staging_Individual s&#xA;CROSS APPLY s.Demographics.nodes('/ns:IndividualSurvey') AS x(c)&#xA;WHERE s.Demographics IS NOT NULL;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
